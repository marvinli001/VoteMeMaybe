{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Vote Me Maybe",
  "version": "0.1.1",
  "identifier": "com.lizhu.tauri-app",
  "build": {
    "beforeDevCommand": "npm run dev:fe",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build:fe",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Vote Me Maybe",
        "width": 1380,
        "height": 860,
        "minWidth": 1180,
        "minHeight": 760,
        "center": true,
        "resizable": true,
        "decorations": false
      }
    ],
    "security": {
      "csp": "default-src 'self' asset: http://asset.localhost; connect-src 'self' ipc: http://ipc.localhost http://localhost:* ws://localhost:* http://127.0.0.1:* ws://127.0.0.1:*; img-src 'self' asset: http://asset.localhost data: blob:; style-src 'self' 'unsafe-inline'; font-src 'self' asset: http://asset.localhost data:;"
    }
  },
  "bundle": {
    "active": false,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
